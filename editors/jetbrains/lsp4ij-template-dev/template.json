{
  "id": "lintropy-dev",
  "name": "Lintropy (dev)",
  "programArgs": {
    "default": "$PROJECT_DIR$/target/debug/lintropy lsp"
  },
  "fileTypeMappings": [
    {
      "fileType": {
        "name": "Rust",
        "patterns": ["*.rs"]
      },
      "languageId": "rust"
    },
    {
      "fileType": {
        "name": "YAML",
        "patterns": ["lintropy.yaml", "*.rule.yaml", "*.rules.yaml"]
      },
      "languageId": "yaml"
    }
  ]
}
